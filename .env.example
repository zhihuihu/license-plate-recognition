# 商用部署时必须配置至少一个高强度 API Key，多个 Key 用逗号分隔。
API_KEYS=replace-with-a-long-random-key
OCR_ENGINE=hyperlpr3
HYPERLPR_MODEL_ROOT=models/hyperlpr3
HYPERLPR_DETECT_LEVEL=low
HYPERLPR_MIN_CONFIDENCE=0.80
# 无外网部署时设为 true；模型不完整会快速失败，不会尝试联网下载。
OFFLINE_MODE=true
PADDLEOCR_FALLBACK=true
PADDLEOCR_MIN_CONFIDENCE=0.80
PADDLEOCR_MODEL_ROOT=models/paddleocr
PLATE_DETECTOR_MODEL_PATH=models/plate_detector/yolo-v9-t-384-license-plates-end2end.onnx
PLATE_DETECTOR_MIN_CONFIDENCE=0.40
PLATE_DETECTOR_PADDING_RATIO=0.08
YOLO26_DETECTOR_MODEL_PATH=models/plate_detector/yolo26s-plate-detect.onnx
YOLO26_RECOGNIZER_MODEL_PATH=models/plate_detector/plate_rec_color.onnx
YOLO26_MIN_CONFIDENCE=0.20
RAPIDOCR_FALLBACK=true

# 生产环境建议保留模型预热，让服务启动时就暴露模型问题。
PRELOAD_OCR_MODEL=true
MAX_UPLOAD_BYTES=10485760
MAX_CONCURRENT_REQUESTS=10
# 独立 OCR 推理实例数；建议先用 1，再按目标机器压测后调整为 2～4。
OCR_INSTANCE_COUNT=1
# 识别槽位满时进入队列，最多等待 30 秒；超时返回 503。
INFERENCE_QUEUE_TIMEOUT_MS=30000
ALLOWED_ORIGINS=
